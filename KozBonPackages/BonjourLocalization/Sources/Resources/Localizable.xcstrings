          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Protocolo Beats Transfer para descubrir y configurar productos de audio Beats, incluyendo auriculares y altavoces."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Protocole Beats Transfer pour la découverte et la configuration des produits audio Beats, y compris les casques, écouteurs et enceintes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beats Transfer Protocol zum Erkennen und Konfigurieren von Beats-Audioprodukten einschließlich Kopfhörern, Ohrhörern und Lautsprechern."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ヘッドフォン、イヤフォン、スピーカーを含むBeatsオーディオ製品の検出と設定のためのBeats Transferプロトコル。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Beats Transfer协议，用于发现和配置Beats音频产品，包括头戴式耳机、耳塞和扬声器。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Beats Transfer Protocol لاكتشاف منتجات الصوت من Beats وتهيئتها، بما في ذلك السمّاعات والسمّاعات الداخلية ومكبّرات الصوت."
          }
        },
        "he": {
          "stringUnit": {
