    "chat_error_too_long": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your message is too long. Please keep it under %lld characters."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu mensaje es demasiado largo. Mántenlo bajo %lld caracteres."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre message est trop long. Limitez-le à moins de %lld caractères."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Nachricht ist zu lang. Halte sie unter %lld Zeichen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メッセージが長すぎます。%lld文字以下にしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的消息太长了。请保持在%lld字符以内。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "رسالتك طويلة جدًا. يرجى إبقاؤها أقل من %lld حرفًا."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ההודעה שלך ארוכה מדי. אנא הקפד שתהיה קצרה מ-%lld תווים."
          }
        }
      }
    },
    "chat_error_prompt_injection": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I can't process that request. I'm designed to answer questions about Bonjour services and the KozBon app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No puedo procesar esa solicitud. Estoy diseñado para responder preguntas sobre servicios Bonjour y la app KozBon."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne peux pas traiter cette demande. Je suis conçu pour répondre aux questions sur les services Bonjour et l’app KozBon."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Anfrage kann ich nicht verarbeiten. Ich bin dafür entworfen, Fragen zu Bonjour-Diensten und der KozBon-App zu beantworten."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "その要求は処理できません。BonjourサービスとKozBonアプリに関する質問に回答するために設計されています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我无法处理此请求。我的设计用于回答关于Bonjour服务和KozBon应用的问题。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يمكنني معالجة هذا الطلب. أنا مصمم للإجابة على أسئلة حول خدمات Bonjour وتطبيق KozBon."
          }
        },
        "he": {
