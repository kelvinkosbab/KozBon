        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eso no parece una clave de API de Anthropic. Las claves comienzan por «sk-ant-»."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela ne ressemble pas à une clé d'API Anthropic. Les clés commencent par « sk-ant- »."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
