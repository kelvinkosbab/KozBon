    "settings_reset_footer": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will restore all settings to their original values and remove any custom service types you have created."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto restaurará todos los ajustes a sus valores originales y eliminará los tipos de servicio personalizados que haya creado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela restaurera tous les réglages à leurs valeurs d’origine et supprimera les types de service personnalisés que vous avez créés."
          }
        },
        "de": {
