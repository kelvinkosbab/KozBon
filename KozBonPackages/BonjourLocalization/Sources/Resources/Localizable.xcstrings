        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Protocolo de compartición de archivos SMB2/SMB3 utilizado por sistemas Windows modernos para mejorar el rendimiento y la seguridad sobre el protocolo SMB original."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
