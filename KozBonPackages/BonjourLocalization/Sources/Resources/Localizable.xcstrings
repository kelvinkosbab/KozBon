          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS-Geräteinformationsübertragung zur Identifizierung von Mac-Computern im lokalen Netzwerk."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
