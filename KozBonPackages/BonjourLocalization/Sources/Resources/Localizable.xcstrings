    "settings_ai_backend_apple_subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On-device by default. No data leaves your device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En el dispositivo de forma predeterminada. Ningún dato sale del dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sur l'appareil par défaut. Aucune donnée ne quitte l'appareil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standardmäßig auf dem Gerät. Keine Daten verlassen Ihr Gerät."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デフォルトでデバイス上で実行。データはデバイスから出ません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认在设备上运行。数据不会离开您的设备。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتراضيًا على الجهاز. لا تغادر أي بيانات جهازك."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "כברירת מחדל במכשיר. שום נתונים לא יוצאים מהמכשיר שלך."
          }
        }
      }
    },
    "settings_ai_backend_anthropic_subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud, via your own Anthropic account. Larger context window."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nube, mediante tu propia cuenta de Anthropic. Ventana de contexto más amplia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud, via votre propre compte Anthropic. Fenêtre contextuelle plus large."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud, über Ihr eigenes Anthropic-Konto. Größeres Kontextfenster."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クラウド経由、ご自身の Anthropic アカウントを使用。より広いコンテキストウィンドウ。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "云端，通过您自己的 Anthropic 账户。更大的上下文窗口。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "السحابة، عبر حساب Anthropic الخاص بك. نافذة سياق أكبر."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ענן, באמצעות חשבון Anthropic האישי שלך. חלון הקשר גדול יותר."
          }
        }
      }
    },
    "settings_ai_cloud_footer": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your questions are sent to Anthropic's API using your own account. Network and service names from your local network are included in the request."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus preguntas se envían a la API de Anthropic con tu propia cuenta. Los nombres de red y servicios de tu red local se incluyen en la solicitud."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos questions sont envoyées à l'API d'Anthropic avec votre compte. Les noms de réseau et de service de votre réseau local sont inclus dans la requête."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ihre Fragen werden mit Ihrem Konto an die Anthropic-API gesendet. Netzwerk- und Dienstnamen aus Ihrem lokalen Netzwerk werden in der Anfrage übertragen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ご質問はあなたのアカウントを使って Anthropic の API に送信されます。ローカルネットワーク上のネットワーク名やサービス名がリクエストに含まれます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的问题将通过您自己的账户发送到 Anthropic 的 API。本地网络中的网络名称和服务名称会包含在请求中。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُرسل أسئلتك إلى واجهة Anthropic البرمجية باستخدام حسابك الخاص. تُضمَّن أسماء الشبكة والخدمات من شبكتك المحلية في الطلب."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "השאלות שלך נשלחות אל ה‑API של Anthropic באמצעות החשבון האישי שלך. שמות הרשת והשירותים מהרשת המקומית שלך נכללים בבקשה."
          }
        }
      }
    },
