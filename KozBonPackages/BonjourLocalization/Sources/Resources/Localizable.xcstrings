          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Anthropic の API キーのように見えません。キーは「sk-ant-」で始まります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
