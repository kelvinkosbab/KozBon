    },
    "Used by the AirPort Extreme Base Station to share USB printers. Printer Setup Utility browses for AirPort Extreme shared USB printers which use the Remote I/O USB Printer Protocol starting in Mac OS X 10.3.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Used by the AirPort Extreme Base Station to share USB printers. Printer Setup Utility browses for AirPort Extreme shared USB printers which use the Remote I/O USB Printer Protocol starting in Mac OS X 10.3."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizado por la estación base AirPort Extreme para compartir impresoras USB. La utilidad de configuración de impresoras busca impresoras USB compartidas de AirPort Extreme que utilizan el protocolo Remote I/O USB Printer a partir de Mac OS X 10.3."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisé par la borne AirPort Extreme pour partager des imprimantes USB. L'utilitaire de configuration d'imprimante recherche les imprimantes USB partagées AirPort Extreme utilisant le protocole Remote I/O USB Printer à partir de Mac OS X 10.3."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwendet von der AirPort Extreme-Basisstation zum Teilen von USB-Druckern. Das Drucker-Konfigurationsprogramm sucht ab Mac OS X 10.3 nach gemeinsam genutzten AirPort Extreme USB-Druckern, die das Remote I/O USB Printer Protocol verwenden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "USBプリンターを共有するためにAirPort Extremeベースステーションで使用されます。Mac OS X 10.3以降、プリンタ設定ユーティリティがRemote I/O USB Printer Protocolを使用するAirPort Extreme共有USBプリンターをブラウズします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "被AirPort Extreme基站用于共享USB打印机。打印机设置实用工具从Mac OS X 10.3开始浏览使用Remote I/O USB Printer Protocol的AirPort Extreme共享USB打印机。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تستخدمه AirPort Extreme Base Station لمشاركة طابعات USB. يبحث Printer Setup Utility عن طابعات USB المشتركة عبر AirPort Extreme التي تستخدم Remote I/O USB Printer Protocol بدءًا من Mac OS X 10.3."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "בשימוש AirPort Extreme Base Station לשיתוף מדפסות USB. Printer Setup Utility מחפש מדפסות USB משותפות של AirPort Extreme שמשתמשות ב-Remote I/O USB Printer Protocol החל מ-Mac OS X 10.3."
          }
        }
      }
    },
