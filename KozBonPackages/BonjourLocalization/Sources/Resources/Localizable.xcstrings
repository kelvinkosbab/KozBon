    "PostgreSQL relational database server. PostgreSQL supports Bonjour-based service discovery when configured with bonjour = on.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PostgreSQL relational database server. PostgreSQL supports Bonjour-based service discovery when configured with bonjour = on."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Servidor de base de datos relacional PostgreSQL. PostgreSQL soporta el descubrimiento de servicios basado en Bonjour cuando se configura con bonjour = on."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Serveur de base de données relationnelle PostgreSQL. PostgreSQL prend en charge la découverte de services basée sur Bonjour lorsqu'il est configuré avec bonjour = on."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "PostgreSQL relationaler Datenbankserver. PostgreSQL unterstützt Bonjour-basierte Diensterkennung bei Konfiguration mit bonjour = on."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PostgreSQLリレーショナルデータベースサーバー。bonjour = onで設定するとBonjourベースのサービス検出をサポートします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PostgreSQL关系数据库服务器。当配置bonjour = on时，PostgreSQL支持基于Bonjour的服务发现。"
          }
        }
      }
    },
    "Print Center browses for IPP printers starting in Mac OS X 10.2. For more information on creating a Bonjour printer, please see the Bonjour Printing Specification.": {
