    "guidance_create_service_type": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tips: Use a short, human-readable name (e.g., “Web Server”). For the type, follow the IANA service-name format — lowercase letters, digits, and hyphens only. The app adds the leading underscore and transport suffix automatically."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Consejos: Usa un nombre corto y legible (por ejemplo, «Servidor web»). Para el tipo, sigue el formato de nombre de servicio IANA: solo letras minúsculas, dígitos y guiones. La app agrega automáticamente el guion bajo inicial y el sufijo de transporte."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conseils : Utilisez un nom court et lisible (p. ex. « Serveur web »). Pour le type, suivez le format de nom de service IANA — lettres minuscules, chiffres et tirets uniquement. L’app ajoute automatiquement le tiret bas initial et le suffixe de transport."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tipps: Verwende einen kurzen, lesbaren Namen (z. B. „Webserver“). Für den Typ nutze das IANA-Dienstnamensformat — nur Kleinbuchstaben, Ziffern und Bindestriche. Die App fügt den führenden Unterstrich und das Transport-Suffix automatisch hinzu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ヒント: 短くて読みやすい名前を使用してください（例:「Webサーバー」）。タイプにはIANAサービス名形式を使います — 小文字、数字、ハイフンのみ。アプリは先頭のアンダースコアと転送層のサフィックスを自動的に追加します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提示：使用简短、易读的名称（例如「Web服务器」）。类型请遵循IANA服务名称格式——仅使用小写字母、数字和连字符。应用会自动添加开头的下划线和传输层后缀。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نصائح: استخدم اسمًا قصيرًا وسهل القراءة (مثل «خادم ويب»). للنوع، اتبع تنسيق اسم خدمة IANA — أحرف صغيرة وأرقام وشرطات فقط. يضيف التطبيق تلقائيًا الشرطة السفلية الافتتاحية ولاحقة طبقة النقل."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "טיפים: השתמש בשם קצר וקריא (לדוגמה, «שרת ווב»). עבור הסוג, פעל לפי תבנית שם שירות IANA — אותיות קטנות, ספרות ומקפים בלבד. האפליקציה מוסיפה אוטומטית את הקו התחתון המוביל ואת סיומת שכבת התעבורה."
          }
        }
      }
    },
    "guidance_txt_record": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "TXT records are optional key-value metadata broadcast alongside your service. Clients read them before connecting to learn about capabilities — a printer might advertise its color and duplex support, or a media server might list streaming protocols. Keys are short ASCII identifiers; values can be any text. Leave the list empty if your service doesn't need any."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los registros TXT son metadatos opcionales en formato clave-valor que se difunden junto con tu servicio. Los clientes los leen antes de conectarse para conocer las capacidades del servicio: una impresora podría anunciar su soporte de color y dúplex, o un servidor multimedia podría enumerar los protocolos de streaming. Las claves son identificadores ASCII cortos; los valores pueden ser cualquier texto. Deja la lista vacía si tu servicio no necesita ninguno."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les enregistrements TXT sont des métadonnées clé-valeur facultatives diffusées avec votre service. Les clients les lisent avant de se connecter pour découvrir ses capacités — une imprimante peut annoncer la prise en charge de la couleur et du recto-verso, ou un serveur multimédia peut lister ses protocoles de streaming. Les clés sont de courts identifiants ASCII ; les valeurs peuvent être n’importe quel texte. Laissez la liste vide si votre service n’en a pas besoin."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "TXT-Einträge sind optionale Schlüssel-Wert-Metadaten, die zusammen mit deinem Dienst verbreitet werden. Clients lesen sie vor dem Verbinden, um die Fähigkeiten zu erfahren — ein Drucker kann etwa Farb- und Duplex-Unterstützung ankündigen, ein Medienserver seine Streaming-Protokolle auflisten. Schlüssel sind kurze ASCII-Bezeichner; Werte können beliebiger Text sein. Lass die Liste leer, wenn dein Dienst keine benötigt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "TXTレコードは、サービスとともに配信されるオプションのキーと値のメタデータです。クライアントは接続前にこれを読み取り、サービスの機能を確認します。例えば、プリンタはカラーや両面印刷の対応状況を示し、メディアサーバはストリーミングプロトコルを列挙できます。キーは短いASCII識別子で、値は任意のテキストです。サービスに必要なければリストを空のままにしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "TXT 记录是与您的服务一起广播的可选键值元数据。客户端会在连接前读取这些信息以了解服务的能力——例如打印机可以宣告其彩色和双面打印支持，媒体服务器可以列出支持的流媒体协议。键是简短的 ASCII 标识符；值可以是任意文本。如果您的服务不需要，请将列表留空。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سجلات TXT هي بيانات وصفية اختيارية بصيغة مفتاح-قيمة تُبثّ مع خدمتك. تقرأها العملاء قبل الاتصال لمعرفة الإمكانيات — قد تعلن الطابعة عن دعمها للألوان والطباعة على الوجهين، أو قد يسرد خادم الوسائط بروتوكولات البث. المفاتيح معرّفات ASCII قصيرة؛ والقيم يمكن أن تكون أي نص. اترك القائمة فارغة إذا كانت خدمتك لا تحتاج إلى أي منها."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "רשומות TXT הן מטא-נתונים אופציונליים בצמדי מפתח-ערך המשודרים יחד עם השירות שלך. לקוחות קוראים אותן לפני התחברות כדי ללמוד על יכולות — מדפסת עשויה לפרסם תמיכה בצבע ובדו-צדדי, או ששרת מדיה ירשום פרוטוקולי הזרמה. המפתחות הם מזהי ASCII קצרים; הערכים יכולים להיות כל טקסט. השאר את הרשימה ריקה אם השירות שלך לא צריך אף אחת מהן."
          }
        }
      }
    },
    "guidance_service_port_hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The port your service listens on. Pick any unused value from 1024–65535 — lower ports are reserved for system services."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El puerto en el que escucha tu servicio. Elige cualquier valor libre entre 1024 y 65535 — los puertos inferiores están reservados para servicios del sistema."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le port sur lequel votre service écoute. Choisissez une valeur libre entre 1024 et 65535 — les ports inférieurs sont réservés aux services système."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Port, auf dem dein Dienst lauscht. Wähle einen freien Wert zwischen 1024 und 65535 — niedrigere Ports sind für Systemdienste reserviert."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サービスがリッスンするポートです。1024〜65535 の未使用の値を選んでください — それ未満はシステムサービス用に予約されています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的服务侦听的端口。请选择 1024–65535 之间任何未使用的值——更低的端口为系统服务保留。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المنفذ الذي تستمع عليه خدمتك. اختر أي قيمة غير مستخدمة من 1024 إلى 65535 — المنافذ الأدنى محجوزة لخدمات النظام."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "היציאה שעליה השירות שלך מקשיב. בחר ערך פנוי כלשהו בטווח 1024–65535 — יציאות נמוכות יותר שמורות לשירותי המערכת."
          }
        }
      }
    },
    "guidance_service_name_hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The label users see when browsing for this service from other devices — for example, “Living Room Printer” in a Choose Printer picker. This is the friendly display name, not the technical identifier other apps look up."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El nombre que ven los usuarios al buscar este servicio desde otros dispositivos — por ejemplo, «Impresora Salón» en un selector de impresora. Es el nombre legible, no el identificador técnico que buscan otras aplicaciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le nom que les utilisateurs voient lorsqu'ils recherchent ce service depuis d'autres appareils — par exemple, « Imprimante salon » dans un sélecteur d'imprimante. C'est le nom convivial, pas l'identifiant technique que recherchent les autres applications."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Name, den Benutzer sehen, wenn sie von anderen Geräten nach diesem Dienst suchen — zum Beispiel „Wohnzimmer-Drucker“ in einem Drucker-Auswahldialog. Der lesbare Anzeigename, nicht der technische Identifier, nach dem andere Apps suchen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "他のデバイスからこのサービスを検索したときにユーザーに表示される名前です — 例えばプリンター選択ダイアログの「リビングのプリンター」など。他のアプリが検索する技術的な識別子ではなく、人間が読みやすい表示名です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "其他设备搜索此服务时用户看到的名称——例如打印机选择器中的「客厅打印机」。这是面向用户的显示名称，不是其他应用查找时使用的技术标识符。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الاسم الذي يراه المستخدمون عند البحث عن هذه الخدمة من أجهزة أخرى — مثلًا «طابعة غرفة المعيشة» في قائمة اختيار طابعة. هذا هو اسم العرض، وليس المعرّف التقني الذي تبحث عنه التطبيقات الأخرى."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "השם שמשתמשים רואים כשהם מחפשים את השירות הזה ממכשירים אחרים — לדוגמה, «מדפסת הסלון» בבורר מדפסות. זהו שם התצוגה הידידותי, לא המזהה הטכני שאפליקציות אחרות מחפשות."
          }
        }
      }
    },
    "guidance_bonjour_type_hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The protocol identifier other devices look up to find services of this kind. Apps browse for a specific type — web browsers look for `_http._tcp`, AirPlay receivers for `_airplay._tcp`. Devices that aren't browsing for the exact type you publish won't see your service."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El identificador de protocolo que otros dispositivos buscan para encontrar servicios de este tipo. Las apps buscan un tipo específico — los navegadores web buscan `_http._tcp`, los receptores AirPlay buscan `_airplay._tcp`. Los dispositivos que no busquen exactamente el tipo que publicas no verán tu servicio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'identifiant de protocole que les autres appareils recherchent pour trouver des services de ce type. Les apps recherchent un type spécifique — les navigateurs web cherchent `_http._tcp`, les récepteurs AirPlay cherchent `_airplay._tcp`. Les appareils qui ne recherchent pas exactement le type que vous publiez ne verront pas votre service."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Protokoll-Identifier, nach dem andere Geräte suchen, um Dienste dieser Art zu finden. Apps suchen nach einem bestimmten Typ — Webbrowser nach `_http._tcp`, AirPlay-Empfänger nach `_airplay._tcp`. Geräte, die nicht genau den von dir veröffentlichten Typ suchen, sehen deinen Dienst nicht."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "他のデバイスがこの種のサービスを見つけるために検索するプロトコル識別子です。各アプリは特定のタイプを検索します — Webブラウザは `_http._tcp`、AirPlayレシーバーは `_airplay._tcp` を探します。あなたが公開した正確なタイプを検索しないデバイスからは、このサービスは見えません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "其他设备查找此类服务时使用的协议标识符。各类应用会搜索特定类型——网络浏览器搜索 `_http._tcp`，AirPlay 接收器搜索 `_airplay._tcp`。不搜索你所发布的确切类型的设备将看不到你的服务。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "معرّف البروتوكول الذي تبحث عنه الأجهزة الأخرى للعثور على خدمات من هذا النوع. تبحث التطبيقات عن نوع محدد — تبحث متصفحات الويب عن `_http._tcp`، ومستقبلات AirPlay عن `_airplay._tcp`. الأجهزة التي لا تبحث عن النوع نفسه الذي تنشره لن ترى خدمتك."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מזהה הפרוטוקול שמכשירים אחרים מחפשים כדי למצוא שירותים מהסוג הזה. אפליקציות מחפשות סוג ספציפי — דפדפני אינטרנט מחפשים את `_http._tcp`, מקלטי AirPlay את `_airplay._tcp`. מכשירים שאינם מחפשים בדיוק את הסוג שאתה מפרסם לא יראו את השירות שלך."
          }
        }
      }
    },
    "guidance_service_domain_hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use `local.` for home and office networks. Custom domains only work if your DNS server hosts DNS-SD records — most don't."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa `local.` en redes domésticas y de oficina. Los dominios personalizados solo funcionan si tu servidor DNS aloja registros DNS-SD — la mayoría no."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez `local.` pour les réseaux domestiques et professionnels. Les domaines personnalisés ne fonctionnent que si votre serveur DNS héberge des enregistrements DNS-SD — la plupart ne le font pas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwende `local.` für Heim- und Büronetzwerke. Benutzerdefinierte Domains funktionieren nur, wenn dein DNS-Server DNS-SD-Einträge hostet — die meisten tun das nicht."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "家庭やオフィスのネットワークでは `local.` を使ってください。カスタムドメインは DNS サーバーが DNS-SD レコードをホストする場合のみ機能します — ほとんどはそうではありません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "家庭和办公网络请使用 `local.`。自定义域名仅在您的 DNS 服务器承载 DNS-SD 记录时才有效——大多数都不会。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم `local.` للشبكات المنزلية والمكتبية. لا تعمل النطاقات المخصصة إلا إذا كان خادم DNS لديك يستضيف سجلات DNS-SD — ومعظمها لا يفعل ذلك."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "השתמש ב-`local.` ברשתות ביתיות ומשרדיות. תחומים מותאמים אישית פועלים רק אם שרת ה-DNS שלך מארח רשומות DNS-SD — רובם לא."
          }
        }
      }
    },
