    "settings_ai_cloud_model_opus_subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Most capable. 200K context window. Best for deep reasoning about complex networks."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El más capaz. Ventana de contexto de 200K. Ideal para razonamientos profundos sobre redes complejas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le plus performant. Fenêtre contextuelle de 200K. Idéal pour un raisonnement approfondi sur des réseaux complexes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Am leistungsfähigsten. 200K-Kontextfenster. Ideal für tiefgehende Analysen komplexer Netzwerke."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最も高性能。200K のコンテキストウィンドウ。複雑なネットワークの詳細な推論に最適。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "能力最强。200K 上下文窗口。最适合对复杂网络进行深入推理。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الأكثر قدرة. نافذة سياق بحجم 200 ألف. الأنسب للتفكير العميق في الشبكات المعقدة."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "החזק ביותר. חלון הקשר של 200K. הטוב ביותר לניתוח עמוק של רשתות מורכבות."
          }
        }
      }
    },
    "settings_ai_cloud_model_sonnet_subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Balanced. 200K context window. Recommended for most questions about your network."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Equilibrado. Ventana de contexto de 200K. Recomendado para la mayoría de preguntas sobre tu red."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Équilibré. Fenêtre contextuelle de 200K. Recommandé pour la plupart des questions sur votre réseau."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausgewogen. 200K-Kontextfenster. Empfohlen für die meisten Fragen zu Ihrem Netzwerk."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バランス型。200K のコンテキストウィンドウ。ネットワークに関するほとんどの質問に推奨。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "均衡。200K 上下文窗口。推荐用于您网络的大多数问题。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "متوازن. نافذة سياق بحجم 200 ألف. موصى به لمعظم الأسئلة حول شبكتك."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מאוזן. חלון הקשר של 200K. מומלץ לרוב השאלות על הרשת שלך."
          }
        }
      }
    },
    "settings_ai_cloud_model_haiku_subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fastest, lowest cost. 200K context window. Best for quick service explanations."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El más rápido y económico. Ventana de contexto de 200K. Ideal para explicaciones rápidas de servicios."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le plus rapide et le moins cher. Fenêtre contextuelle de 200K. Idéal pour des explications rapides de services."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Am schnellsten und günstigsten. 200K-Kontextfenster. Ideal für schnelle Diensterklärungen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最速・最安。200K のコンテキストウィンドウ。サービスの簡潔な説明に最適。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "速度最快、成本最低。200K 上下文窗口。最适合快速服务说明。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الأسرع والأقل تكلفة. نافذة سياق بحجم 200 ألف. الأنسب للشروحات السريعة للخدمات."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "המהיר ביותר ובעלות הנמוכה ביותר. חלון הקשר של 200K. הטוב ביותר להסברים מהירים על שירותים."
          }
        }
      }
    },
    "a11y_ai_backend_picker_hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose between on-device Apple Intelligence and your own Anthropic Claude account."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige entre Apple Intelligence en el dispositivo y tu propia cuenta de Anthropic Claude."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez entre Apple Intelligence sur l'appareil et votre propre compte Anthropic Claude."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie zwischen Apple Intelligence auf dem Gerät und Ihrem eigenen Anthropic-Claude-Konto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デバイス上の Apple Intelligence と、ご自身の Anthropic Claude アカウントから選択します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在设备端 Apple Intelligence 与您自己的 Anthropic Claude 账户之间选择。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر بين Apple Intelligence على الجهاز وحساب Anthropic Claude الخاص بك."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "בחר בין Apple Intelligence במכשיר לבין חשבון Anthropic Claude האישי שלך."
          }
        }
      }
    },
    "a11y_ai_cloud_sign_in_hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stores your Anthropic API key in the device Keychain. KozBon never sees it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Guarda tu clave de API de Anthropic en el Llavero del dispositivo. KozBon nunca la ve."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Stocke votre clé d'API Anthropic dans le trousseau de l'appareil. KozBon ne la voit jamais."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speichert Ihren Anthropic-API-Schlüssel im Schlüsselbund des Geräts. KozBon sieht ihn nie."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Anthropic の API キーをデバイスのキーチェーンに保存します。KozBon が確認することはありません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将您的 Anthropic API 密钥保存到设备钥匙串中。KozBon 不会看到密钥。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحفظ مفتاح Anthropic API الخاص بك في سلسلة مفاتيح الجهاز. لن يراه KozBon أبدًا."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שומר את מפתח ה‑API של Anthropic שלך במחזיק המפתחות של המכשיר. KozBon לעולם לא רואה אותו."
          }
        }
      }
    },
    "a11y_ai_cloud_sign_out_hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Removes your Anthropic API key from the device Keychain."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina tu clave de API de Anthropic del Llavero del dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprime votre clé d'API Anthropic du trousseau de l'appareil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernt Ihren Anthropic-API-Schlüssel aus dem Schlüsselbund des Geräts."
          }
        },
        "ja": {
