      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Restores your last conversation when you reopen the app, capped to the 200 most recent messages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Restaura tu última conversación al volver a abrir la app, con un límite de los 200 mensajes más recientes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Restaure votre dernière conversation à la réouverture de l'app, dans la limite des 200 messages les plus récents."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stellt deine letzte Unterhaltung beim erneuten Öffnen der App wieder her, begrenzt auf die 200 neuesten Nachrichten."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリを再度開いたときに直近の会話を復元します（最新の 200 件まで）。"
