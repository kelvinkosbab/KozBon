            "state": "translated",
            "value": "Message Queuing Telemetry Transport (MQTT) es un protocolo de mensajería ligero ampliamente utilizado en sistemas IoT y de automatización del hogar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Message Queuing Telemetry Transport (MQTT) est un protocole de messagerie léger largement utilisé dans les systèmes IoT et de domotique."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Message Queuing Telemetry Transport (MQTT) ist ein leichtgewichtiges Nachrichtenprotokoll, das in IoT- und Heimautomatisierungssystemen weit verbreitet ist."
          }
        },
        "ja": {
          "stringUnit": {
