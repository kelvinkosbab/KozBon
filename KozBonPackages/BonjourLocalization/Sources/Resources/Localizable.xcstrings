    "chat_sign_in_to_github_body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub is selected but no token is configured. Sign in to start chatting with GPT-4o."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Has seleccionado GitHub, pero no hay ningún token configurado. Inicia sesión para empezar a chatear con GPT-4o."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub est sélectionné, mais aucun jeton n’est configuré. Connectez-vous pour discuter avec GPT-4o."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub ist ausgewählt, aber es ist kein Token konfiguriert. Melde dich an, um mit GPT-4o zu chatten."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "GitHub が選択されていますが、トークンが設定されていません。サインインして GPT-4o とのチャットを開始してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已选择 GitHub，但尚未配置令牌。请登录以与 GPT-4o 开始聊天。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم اختيار GitHub لكن لم يتم إعداد أي رمز. سجّل الدخول لبدء المحادثة مع GPT-4o."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "‏GitHub נבחר, אך לא הוגדר אסימון. התחבר כדי להתחיל לשוחח עם GPT-4o."
          }
        }
      }
    },
