          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTPS (HTTP sobre TLS) para comunicación web segura. Utilizado por navegadores web, App Store, iCloud, FaceTime y la mayoría de los servicios de Apple que requieren conexiones cifradas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
