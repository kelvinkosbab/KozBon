          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las máquinas Mac OS X Server publican este servicio a partir de Mac OS X 10.3. Server Admin busca este servicio a partir de Mac OS X Server 10.3."
          }
        },
        "fr": {
          "stringUnit": {
