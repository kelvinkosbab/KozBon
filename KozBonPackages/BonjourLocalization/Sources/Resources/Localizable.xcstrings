    "Prometheus systems monitoring and alerting toolkit for collecting and querying metrics from configured targets.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Prometheus systems monitoring and alerting toolkit for collecting and querying metrics from configured targets."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Kit de herramientas de monitoreo y alertas de sistemas Prometheus para recopilar y consultar métricas de objetivos configurados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Boîte à outils de surveillance et d'alerte Prometheus pour la collecte et l'interrogation de métriques à partir de cibles configurées."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prometheus Systemüberwachungs- und Alarmierungs-Toolkit zum Sammeln und Abfragen von Metriken von konfigurierten Zielen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定されたターゲットからメトリクスを収集してクエリするためのPrometheusシステム監視およびアラートツールキット。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Prometheus系统监控和警报工具包，用于从配置的目标收集和查询指标。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Prometheus هو مجموعة أدوات لمراقبة الأنظمة وإطلاق التنبيهات، تستخدم لجمع المقاييس والاستعلام عنها من الأهداف المُهيَّأة."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Prometheus היא ערכת כלים לניטור מערכות ולהתראות, לאיסוף ושאילתת מטריקות מיעדים שהוגדרו."
          }
        }
      }
    },
