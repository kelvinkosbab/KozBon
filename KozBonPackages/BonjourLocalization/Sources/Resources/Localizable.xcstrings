    "settings_ai_cloud_sign_in_prompt": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paste your Anthropic API key. KozBon stores it in the device Keychain and uses it only for your AI requests — KozBon never sees your key on a server."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pega tu clave de API de Anthropic. KozBon la guarda en el Llavero del dispositivo y la usa solo para tus solicitudes de IA — KozBon nunca ve tu clave en un servidor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Collez votre clé d'API Anthropic. KozBon la stocke dans le trousseau de l'appareil et l'utilise uniquement pour vos requêtes IA — KozBon ne voit jamais votre clé sur un serveur."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie Ihren Anthropic-API-Schlüssel ein. KozBon speichert ihn im Schlüsselbund des Geräts und verwendet ihn nur für Ihre KI-Anfragen — KozBon sieht Ihren Schlüssel niemals auf einem Server."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Anthropic の API キーを貼り付けてください。KozBon はキーをデバイスのキーチェーンに保存し、あなたの AI リクエストにのみ使用します — KozBon がサーバー上でキーを見ることはありません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "粘贴您的 Anthropic API 密钥。KozBon 将其保存在设备钥匙串中，仅用于您的 AI 请求 — KozBon 永远不会在服务器上看到您的密钥。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الصق مفتاح Anthropic API الخاص بك. يحفظه KozBon في سلسلة مفاتيح الجهاز ويستخدمه فقط لطلبات الذكاء الاصطناعي الخاصة بك — لا يرى KozBon مفتاحك أبداً على خادم."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הדבק את מפתח ה‑API של Anthropic שלך. KozBon שומר אותו במחזיק המפתחות של המכשיר ומשתמש בו רק לבקשות הבינה המלאכותית שלך — KozBon לעולם לא רואה את המפתח שלך בשרת."
          }
        }
      }
    },
