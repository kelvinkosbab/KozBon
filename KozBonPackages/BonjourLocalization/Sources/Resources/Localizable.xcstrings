    "settings_ai_analysis_footer": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, you can long-press a discovered service for an on-device explanation, and the Chat tab is available for conversations about your network. Everything runs privately on your device — no data is sent to external servers."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando está activado, puedes mantener presionado un servicio descubierto para obtener una explicación en el dispositivo, y la pestaña Chat está disponible para conversar sobre tu red. Todo se ejecuta de forma privada en tu dispositivo, sin enviar datos a servidores externos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsque cette option est activée, vous pouvez appuyer longuement sur un service découvert pour obtenir une explication sur l'appareil, et l'onglet Chat est disponible pour des conversations à propos de votre réseau. Tout s'exécute en privé sur votre appareil — aucune donnée n'est envoyée à des serveurs externes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn aktiviert, können Sie lange auf einen entdeckten Dienst drücken, um eine Erklärung auf dem Gerät zu erhalten, und der Chat-Tab steht für Gespräche über Ihr Netzwerk zur Verfügung. Alles läuft privat auf Ihrem Gerät — keine Daten werden an externe Server gesendet."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にすると、発見したサービスを長押ししてデバイス上の説明を確認でき、Chatタブでネットワークについての会話を行えます。すべてデバイス上でプライベートに実行され、外部サーバーにデータは送信されません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用后，您可以长按已发现的服务以获取设备端的说明，并可使用「聊天」标签就您的网络进行对话。所有内容均在您的设备上私密运行，不会向外部服务器发送任何数据。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عند التفعيل، يمكنك الضغط مطوّلاً على خدمة مكتشفة للحصول على شرح على الجهاز، وتصبح علامة تبويب المحادثة متاحة للحديث عن شبكتك. يعمل كل شيء بشكل خاص على جهازك — لا يتم إرسال أي بيانات إلى خوادم خارجية."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "כאשר תכונה זו מופעלת, ניתן ללחוץ ארוכות על שירות שהתגלה כדי לקבל הסבר על-גבי המכשיר, וכרטיסיית הצ'אט זמינה לשיחות על הרשת שלך. הכל פועל באופן פרטי על המכשיר — לא נשלחים נתונים לשרתים חיצוניים."
          }
        }
      }
    },
    "settings_ai_unavailable_not_enabled": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence is currently turned off. Open Settings → Apple Intelligence & Siri to turn it on."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence está desactivado. Abre Ajustes → Apple Intelligence y Siri para activarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence est actuellement désactivé. Ouvrez Réglages → Apple Intelligence et Siri pour l'activer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence ist derzeit ausgeschaltet. Öffnen Sie Einstellungen → Apple Intelligence & Siri, um es einzuschalten."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence は現在オフになっています。「設定」→「Apple Intelligence と Siri」でオンにしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence 当前已关闭。请打开「设置」→「Apple Intelligence 与 Siri」开启。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence معطّل حاليًا. افتح الإعدادات ← Apple Intelligence و Siri لتفعيله."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence כבוי כעת. פתח את הגדרות ← Apple Intelligence ו-Siri כדי להפעיל אותו."
          }
        }
      }
    },
    "settings_ai_unavailable_model_downloading": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Apple Intelligence model is still downloading. AI features will become available once the download completes."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modelo de Apple Intelligence aún se está descargando. Las funciones de IA estarán disponibles cuando finalice la descarga."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le modèle Apple Intelligence est encore en cours de téléchargement. Les fonctionnalités d'IA seront disponibles une fois le téléchargement terminé."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
