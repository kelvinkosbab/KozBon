          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Matter-Commissioner-Gerät, das neue Matter-Zubehörteile in das Smart-Home-Netzwerk einbinden kann."
          }
        },
        "ja": {
          "stringUnit": {
