        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同じネットワーク上の認証済みコンピュータとAppleデバイス間で音楽、映画、テレビ番組をストリーミングするiTunes Home Sharing。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iTunes Home Sharing，用于在同一网络上的授权电脑和Apple设备之间流式传输音乐、电影和电视节目。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "iTunes Home Sharing لبث الموسيقى والأفلام والبرامج التلفزيونية بين الحواسيب المعتمدة وأجهزة Apple على الشبكة نفسها."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "iTunes Home Sharing להזרמת מוזיקה, סרטים ותוכניות טלוויזיה בין מחשבים מורשים ומכשירי Apple באותה רשת."
          }
        }
      }
    },
    "macOS device information broadcast for identifying Mac computers on the local network.": {
      "extractionState": "manual",
      "localizations": {
