    "HTTPS (HTTP over TLS) for secure web communication. Used by web browsers, App Store, iCloud, FaceTime, and most Apple services requiring encrypted connections.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTPS (HTTP over TLS) for secure web communication. Used by web browsers, App Store, iCloud, FaceTime, and most Apple services requiring encrypted connections."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTPS (HTTP sobre TLS) para comunicación web segura. Utilizado por navegadores web, App Store, iCloud, FaceTime y la mayoría de los servicios de Apple que requieren conexiones cifradas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTPS (HTTP sur TLS) pour la communication web sécurisée. Utilisé par les navigateurs web, l'App Store, iCloud, FaceTime et la plupart des services Apple nécessitant des connexions chiffrées."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
