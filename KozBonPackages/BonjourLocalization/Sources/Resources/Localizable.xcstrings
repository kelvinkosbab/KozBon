        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيُستخدم هذا الوصف لشرح خدمتك عندما يضغط المستخدمون مطوّلاً على «رؤى»."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "התיאור הזה ישמש להסביר את השירות שלך כאשר משתמשים יקישו ארוכות על «תובנות»."
          }
        }
      }
    },
