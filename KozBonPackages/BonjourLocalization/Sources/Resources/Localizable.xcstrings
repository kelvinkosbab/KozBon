        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从设备钥匙串中移除您的 Anthropic API 密钥。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحذف مفتاح Anthropic API الخاص بك من سلسلة مفاتيح الجهاز."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מסיר את מפתח ה‑API של Anthropic שלך ממחזיק המפתחות של המכשיר."
          }
        }
      }
    },
    "settings_ai_backend_section_purpose": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Powers the long-press Insights explanations of discovered services and the Chat tab's conversational assistant."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa las explicaciones de Insights al mantener pulsado un servicio descubierto y el asistente conversacional de la pestaña Chat."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Alimente les explications d'Insights lors d'un appui long sur les services découverts et l'assistant conversationnel de l'onglet Chat."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Treibt die Insights-Erklärungen beim Längerdrücken auf entdeckte Dienste und den dialogorientierten Assistenten im Chat-Tab an."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "発見したサービスを長押ししたときの Insights による説明と、Chat タブの対話アシスタントを支えます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为长按已发现服务时的 Insights 说明以及聊天标签中的对话助手提供支持。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يشغّل شروحات Insights عند الضغط مطوّلاً على الخدمات المكتشفة ومساعد المحادثة في علامة تبويب Chat."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מפעיל את הסברי Insights בלחיצה ארוכה על שירותים שהתגלו ואת עוזר השיחה בכרטיסיית Chat."
          }
        }
      }
    },
    "settings_ai_backend_apple_privacy": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence runs entirely on this device — no data leaves your device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence se ejecuta completamente en este dispositivo: ningún dato sale del dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence s'exécute entièrement sur cet appareil — aucune donnée ne quitte votre appareil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence läuft vollständig auf diesem Gerät — keine Daten verlassen Ihr Gerät."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence は完全にこのデバイス上で動作します — データはデバイスから出ません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence 完全在本设备上运行 —— 数据不会离开您的设备。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يعمل Apple Intelligence بالكامل على هذا الجهاز — لا تغادر أي بيانات جهازك."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence פועל כולו במכשיר זה — שום נתונים לא יוצאים מהמכשיר שלך."
          }
        }
      }
    },
