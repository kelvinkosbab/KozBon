    },
    "VNC remote desktop access protocol. An alternative service type to RFB, commonly advertised by VNC server implementations.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "VNC remote desktop access protocol. An alternative service type to RFB, commonly advertised by VNC server implementations."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Protocolo de acceso a escritorio remoto VNC. Un tipo de servicio alternativo a RFB, comúnmente publicado por implementaciones de servidores VNC."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Protocole d'accès au bureau à distance VNC. Un type de service alternatif à RFB, couramment publié par les implémentations de serveurs VNC."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "VNC Remote-Desktop-Zugriffsprotokoll. Ein alternativer Diensttyp zu RFB, der häufig von VNC-Server-Implementierungen beworben wird."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "VNCリモートデスクトップアクセスプロトコル。RFBの代替サービスタイプで、VNCサーバー実装で一般的にアドバタイズされます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "VNC远程桌面访问协议。RFB的替代服务类型，常由VNC服务器实现广播。"
          }
        }
      }
    },
    "Wi-Fi Calling service for making and receiving phone calls over a Wi-Fi network instead of cellular.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi Calling service for making and receiving phone calls over a Wi-Fi network instead of cellular."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Servicio de llamadas Wi-Fi para realizar y recibir llamadas telefónicas a través de una red Wi-Fi en lugar de la red celular."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Service d'appels Wi-Fi pour passer et recevoir des appels téléphoniques via un réseau Wi-Fi au lieu du réseau cellulaire."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi Calling-Dienst für Telefonate über ein WLAN-Netzwerk anstelle des Mobilfunknetzes."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "携帯電話ネットワークの代わりにWi-Fiネットワーク経由で電話の発着信を行うWi-Fi Callingサービス。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Wi-Fi通话服务，用于通过Wi-Fi网络而非蜂窝网络拨打和接听电话。"
          }
        }
      }
    },
    "eSCL (AirScan) scanner protocol for driverless network scanning. Supported by most modern network-attached scanners and multifunction printers.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "eSCL (AirScan) scanner protocol for driverless network scanning. Supported by most modern network-attached scanners and multifunction printers."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Protocolo de escáner eSCL (AirScan) para escaneo en red sin controladores. Compatible con la mayoría de los escáneres de red y las impresoras multifunción modernos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Protocole de scanner eSCL (AirScan) pour la numérisation réseau sans pilote. Pris en charge par la plupart des scanners réseau et imprimantes multifonctions modernes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "eSCL (AirScan) Scannerprotokoll für treiberloses Netzwerkscannen. Unterstützt von den meisten modernen Netzwerkscannern und Multifunktionsdruckern."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ドライバーレスネットワークスキャンのためのeSCL（AirScan）スキャナープロトコル。最新のネットワーク接続スキャナーおよび複合プリンターの多くでサポートされています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "eSCL（AirScan）扫描仪协议，用于免驱动网络扫描。大多数现代网络扫描仪和多功能打印机支持此协议。"
          }
        }
      }
    },
    "iTunes Home Sharing for streaming music, movies, and TV shows between authorized computers and Apple devices on the same network.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iTunes Home Sharing for streaming music, movies, and TV shows between authorized computers and Apple devices on the same network."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "iTunes Home Sharing para transmitir música, películas y programas de TV entre ordenadores autorizados y dispositivos Apple en la misma red."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "iTunes Home Sharing pour la diffusion de musique, films et séries entre ordinateurs autorisés et appareils Apple sur le même réseau."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "iTunes Home Sharing zum Streamen von Musik, Filmen und TV-Sendungen zwischen autorisierten Computern und Apple-Geräten im selben Netzwerk."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同じネットワーク上の認証済みコンピュータとAppleデバイス間で音楽、映画、テレビ番組をストリーミングするiTunes Home Sharing。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iTunes Home Sharing，用于在同一网络上的授权电脑和Apple设备之间流式传输音乐、电影和电视节目。"
          }
        }
      }
    },
    "macOS device information broadcast for identifying Mac computers on the local network.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS device information broadcast for identifying Mac computers on the local network."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Difusión de información de dispositivos macOS para identificar ordenadores Mac en la red local."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
