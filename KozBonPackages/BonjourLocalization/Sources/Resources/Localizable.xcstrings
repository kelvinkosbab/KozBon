          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يبحث Finder عن خوادم WebDAV، لكن بسبب خطأ (r. 3171023) فإن النقر المزدوج على خادم مكتشف يفشل في الاتصال."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
