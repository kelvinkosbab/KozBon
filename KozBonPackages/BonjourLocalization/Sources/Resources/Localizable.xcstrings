      }
    },
    "chat_error_prompt_injection": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I can't process that request. I'm designed to answer questions about Bonjour services and the KozBon app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No puedo procesar esa solicitud. Estoy diseñado para responder preguntas sobre servicios Bonjour y la app KozBon."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne peux pas traiter cette demande. Je suis conçu pour répondre aux questions sur les services Bonjour et l’app KozBon."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Anfrage kann ich nicht verarbeiten. Ich bin dafür entworfen, Fragen zu Bonjour-Diensten und der KozBon-App zu beantworten."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "その要求は処理できません。BonjourサービスとKozBonアプリに関する質問に回答するために設計されています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我无法处理此请求。我的设计用于回答关于Bonjour服务和KozBon应用的问题。"
          }
        }
      }
    },
    "chat_error_off_topic": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I can only help with Bonjour services and the KozBon app. What would you like to know about your network?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo puedo ayudarte con servicios Bonjour y la app KozBon. ¿Qué te gustaría saber sobre tu red?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je ne peux vous aider qu’avec les services Bonjour et l’app KozBon. Que voulez-vous savoir sur votre réseau ?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ich kann nur bei Bonjour-Diensten und der KozBon-App helfen. Was möchtest du über dein Netzwerk wissen?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "BonjourサービスとKozBonアプリに関することのみお手伝いできます。ネットワークについて何を知りたいですか？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我只能帮助处理Bonjour服务和KozBon应用相关的问题。您想了解您网络的什么内容？"
          }
        }
      }
    },
