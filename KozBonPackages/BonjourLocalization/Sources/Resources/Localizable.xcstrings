      }
    },
    "The Finder browses for WebDAV servers but because of a bug (r. 3171023), double-clicking a discovered server fails to connect.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Finder browses for WebDAV servers but because of a bug (r. 3171023), double-clicking a discovered server fails to connect."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El Finder busca servidores WebDAV pero debido a un error (r. 3171023), hacer doble clic en un servidor descubierto no logra conectar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le Finder recherche les serveurs WebDAV mais en raison d'un bug (r. 3171023), le double-clic sur un serveur découvert échoue à se connecter."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Finder sucht nach WebDAV-Servern, aber aufgrund eines Fehlers (r. 3171023) schlägt ein Doppelklick auf einen erkannten Server fehl."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "FinderはWebDAVサーバーをブラウズしますが、バグ（r. 3171023）のため、検出されたサーバーをダブルクリックしても接続に失敗します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Finder会浏览WebDAV服务器，但由于一个错误（r. 3171023），双击已发现的服务器无法连接。"
          }
        }
      }
