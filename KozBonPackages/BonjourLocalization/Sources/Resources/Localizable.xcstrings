    "PostgreSQL relational database server. PostgreSQL supports Bonjour-based service discovery when configured with bonjour = on.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PostgreSQL relational database server. PostgreSQL supports Bonjour-based service discovery when configured with bonjour = on."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Servidor de base de datos relacional PostgreSQL. PostgreSQL soporta el descubrimiento de servicios basado en Bonjour cuando se configura con bonjour = on."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Serveur de base de données relationnelle PostgreSQL. PostgreSQL prend en charge la découverte de services basée sur Bonjour lorsqu'il est configuré avec bonjour = on."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "PostgreSQL relationaler Datenbankserver. PostgreSQL unterstützt Bonjour-basierte Diensterkennung bei Konfiguration mit bonjour = on."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PostgreSQLリレーショナルデータベースサーバー。bonjour = onで設定するとBonjourベースのサービス検出をサポートします。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PostgreSQL关系数据库服务器。当配置bonjour = on时，PostgreSQL支持基于Bonjour的服务发现。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "خادم قواعد بيانات PostgreSQL العلائقي. يدعم PostgreSQL اكتشاف الخدمات عبر Bonjour عند تهيئته بـ bonjour = on."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שרת בסיס נתונים יחסי PostgreSQL. PostgreSQL תומך בגילוי שירותים מבוסס Bonjour כשמוגדר עם bonjour = on."
          }
        }
      }
    },
    "Print Center browses for IPP printers starting in Mac OS X 10.2. For more information on creating a Bonjour printer, please see the Bonjour Printing Specification.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Print Center browses for IPP printers starting in Mac OS X 10.2. For more information on creating a Bonjour printer, please see the Bonjour Printing Specification."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Print Center busca impresoras IPP a partir de Mac OS X 10.2. Para más información sobre la creación de una impresora Bonjour, consulte la especificación de impresión Bonjour."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Print Center recherche les imprimantes IPP à partir de Mac OS X 10.2. Pour plus d'informations sur la création d'une imprimante Bonjour, consultez la spécification d'impression Bonjour."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Print Center sucht ab Mac OS X 10.2 nach IPP-Druckern. Weitere Informationen zum Erstellen eines Bonjour-Druckers finden Sie in der Bonjour-Druckspezifikation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac OS X 10.2以降、Print CenterがIPPプリンターをブラウズします。Bonjourプリンターの作成に関する詳細は、Bonjour印刷仕様を参照してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Print Center从Mac OS X 10.2开始浏览IPP打印机。有关创建Bonjour打印机的更多信息，请参阅Bonjour打印规范。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يبحث Print Center عن طابعات IPP بدءًا من Mac OS X 10.2. للمزيد من المعلومات حول إنشاء طابعة Bonjour، يرجى الاطلاع على Bonjour Printing Specification."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "Print Center מחפש מדפסות IPP החל מ-Mac OS X 10.2. למידע נוסף על יצירת מדפסת Bonjour, ראו את Bonjour Printing Specification."
          }
        }
      }
    },
