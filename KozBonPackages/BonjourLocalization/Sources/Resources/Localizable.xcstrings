    "CoAP is a lightweight protocol designed for constrained IoT devices and low-power networks, similar to HTTP but optimized for machine-to-machine communication.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CoAP is a lightweight protocol designed for constrained IoT devices and low-power networks, similar to HTTP but optimized for machine-to-machine communication."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "CoAP es un protocolo ligero diseñado para dispositivos IoT con recursos limitados y redes de bajo consumo, similar a HTTP pero optimizado para comunicación máquina a máquina."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "CoAP est un protocole léger conçu pour les appareils IoT contraints et les réseaux à faible consommation, similaire à HTTP mais optimisé pour la communication machine à machine."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "CoAP ist ein leichtgewichtiges Protokoll für eingeschränkte IoT-Geräte und energiesparende Netzwerke, ähnlich wie HTTP, aber optimiert für Maschine-zu-Maschine-Kommunikation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CoAPは、制約のあるIoTデバイスと低電力ネットワーク向けに設計された軽量プロトコルで、HTTPに似ていますがマシン間通信に最適化されています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "CoAP是一种为受限IoT设备和低功耗网络设计的轻量级协议，类似于HTTP但针对机器对机器通信进行了优化。"
          }
        }
      }
    },
    "DNS-based Service Discovery (DNS-SD) is the meta-query protocol used to enumerate available Bonjour service types on the network.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "DNS-based Service Discovery (DNS-SD) is the meta-query protocol used to enumerate available Bonjour service types on the network."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "DNS-based Service Discovery (DNS-SD) es el protocolo de meta-consulta utilizado para enumerar los tipos de servicios Bonjour disponibles en la red."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "DNS-based Service Discovery (DNS-SD) est le protocole de méta-requête utilisé pour énumérer les types de services Bonjour disponibles sur le réseau."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "DNS-based Service Discovery (DNS-SD) ist das Meta-Abfrageprotokoll zur Auflistung verfügbarer Bonjour-Diensttypen im Netzwerk."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DNS-based Service Discovery（DNS-SD）は、ネットワーク上で利用可能なBonjourサービスタイプを列挙するために使用されるメタクエリプロトコルです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "DNS-based Service Discovery（DNS-SD）是用于枚举网络上可用Bonjour服务类型的元查询协议。"
          }
        }
      }
    },
