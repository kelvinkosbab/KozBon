    "Thread Mesh Commissioning Protocol for Thread border routers such as Apple TV and HomePod. TXT records expose the Thread network name, channel, and PAN ID.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thread Mesh Commissioning Protocol for Thread border routers such as Apple TV and HomePod. TXT records expose the Thread network name, channel, and PAN ID."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Protocolo de comisionado de malla Thread para routers de borde Thread como Apple TV y HomePod. Los registros TXT exponen el nombre de la red Thread, el canal y el PAN ID."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Protocole de commissionnement de maillage Thread pour les routeurs de bordure Thread tels que l'Apple TV et le HomePod. Les enregistrements TXT exposent le nom du réseau Thread, le canal et l'identifiant PAN."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Thread-Mesh-Commissioning-Protokoll für Thread-Border-Router wie Apple TV und HomePod. TXT-Einträge zeigen den Thread-Netzwerknamen, Kanal und PAN-ID."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple TVやHomePodなどのThreadボーダールーター用のThread Meshコミッショニングプロトコル。TXTレコードにはThreadネットワーク名、チャンネル、PAN IDが含まれます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用于Apple TV和HomePod等Thread边界路由器的Thread Mesh调试协议。TXT记录包含Thread网络名称、通道和PAN ID。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بروتوكول Thread Mesh Commissioning لموجِّهات حدود Thread مثل Apple TV و HomePod. تكشف سجلات TXT عن اسم شبكة Thread والقناة و PAN ID."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "פרוטוקול Thread Mesh Commissioning עבור ראוטרי שוליים של Thread כגון Apple TV ו-HomePod. רשומות TXT חושפות את שם רשת ה-Thread, את הערוץ ואת ה-PAN ID."
          }
        }
      }
    },
    "A Matter device in commissioning mode, actively advertising its availability for pairing and setup on the local network.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Matter device in commissioning mode, actively advertising its availability for pairing and setup on the local network."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un dispositivo Matter en modo de comisionado, anunciando activamente su disponibilidad para emparejamiento y configuración en la red local."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un appareil Matter en mode de commissionnement, annonçant activement sa disponibilité pour l'appairage et la configuration sur le réseau local."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Matter-Gerät im Inbetriebnahme-Modus, das aktiv seine Verfügbarkeit für Kopplung und Einrichtung im lokalen Netzwerk bewirbt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コミッショニングモードのMatterデバイスで、ローカルネットワーク上でペアリングとセットアップの可用性をアクティブにアドバタイズしています。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "处于调试模式的Matter设备，正在本地网络上主动广播其配对和设置可用性。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جهاز Matter في وضع التشغيل، يعلن بنشاط عن توفره للإقران والإعداد على الشبكة المحلية."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מכשיר Matter במצב הקצאה, שמשדר באופן פעיל את זמינותו לצימוד ולהתקנה ברשת המקומית."
          }
        }
      }
    },
    "A Matter commissioner device capable of onboarding new Matter accessories onto the smart home network.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A Matter commissioner device capable of onboarding new Matter accessories onto the smart home network."
