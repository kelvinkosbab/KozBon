    "settings_reset_confirmation_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will reset all settings to their default values and remove any custom service types. This action cannot be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto restablecerá todos los ajustes a sus valores predeterminados y eliminará los tipos de servicio personalizados. Esta acción no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela réinitialisera tous les réglages à leurs valeurs par défaut et supprimera les types de service personnalisés. Cette action est irréversible."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden alle Einstellungen auf die Standardwerte zurückgesetzt und benutzerdefinierte Diensttypen entfernt. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての設定をデフォルト値に戻し、カスタムサービスタイプを削除します。この操作は元に戻せません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将把所有设置恢复为默认值，并删除所有自定义服务类型。此操作无法撤消。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي ذلك إلى إعادة تعيين جميع الإعدادات إلى القيم الافتراضية وإزالة أي أنواع خدمات مخصصة. لا يمكن التراجع عن هذا الإجراء."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "פעולה זו תאפס את כל ההגדרות לערכי ברירת המחדל ותסיר סוגי שירות מותאמים אישית. לא ניתן לבטל פעולה זו."
          }
        }
      }
    },
